# ============================================================
# Crypto Quant System - 环境变量模板
# 复制为 .env 并填入真实值。.env 文件禁止入库。
# dry-run / backtest 阶段所有密钥可留空。
# ============================================================

# ---- OKX 交易所（私有接口才需要；公开行情无需填写）----
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
# OKX 账户模式：unified（统一账户）/ classic（经典账户）
OKX_ACCOUNT_MODE=unified
# 持仓模式：net（单向）/ long_short（双向，支持对冲）
OKX_POS_MODE=long_short

# ---- Telegram 监控 ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# ---- DeepSeek AI（策略生成）----
# 获取地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ---- 实盘安全开关（默认全 false，禁止实盘）----
# 任意为 false 时，dry_run=false 的 live 模式将拒绝启动
LIVE_TRADING_CONFIRMED=false
RISK_CONFIG_LOADED=false
KILL_SWITCH_TESTED=false

# ---- 风控参数（可被 risk_config.yaml 覆盖）----
RISK_MAX_LEVERAGE=5
RISK_MAX_SINGLE_ORDER_NOTIONAL=200
RISK_MAX_SYMBOL_NOTIONAL=300
RISK_MAX_TOTAL_NOTIONAL=1000
RISK_MAX_DRAWDOWN_PCT=15
RISK_DAILY_LOSS_PCT=5
RISK_LIQUIDATION_DISTANCE_PCT=10

# ---- 日志级别 ----
LOG_LEVEL=INFO
